{
    "background": {
        "desktopClock": {
            "background": {
                "blur": true,
                "enabled": true,
                "opacity": 0.7
            },
            "enabled": true,
            "invertColors": false,
            "position": "bottom-right",
            "scale": 1,
            "shadow": {
