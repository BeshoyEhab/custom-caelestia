#!/usr/bin/env bash

# ── Core palette ─────────────────────────────────────────────────────
export THEME_BG="0d0d0d"           # obsidian black
export THEME_BG_ALPHA="dd"         # alpha for bars/panels (0=transparent, ff=opaque)
export THEME_SURFACE="141414"      # slightly lifted surface
export THEME_SURFACE2="1c1c1c"     # second level surface (menus, dropdowns)
export THEME_BORDER="1f1f1f"       # subtle border between surfaces

export THEME_GOLD="f0a500"         # primary accent — active border, highlights
export THEME_GOLD_DIM="c47d00"     # secondary gold — gradient end, hover states
export THEME_GOLD_MUTED="7a5200"   # inactive/dimmed gold

export THEME_TEXT="e8e0d0"         # primary text — warm white
export THEME_TEXT_DIM="a09888"     # secondary text — muted
export THEME_TEXT_HINT="5a5248"    # hint / placeholder text

# ── Semantic colors ───────────────────────────────────────────────────
export THEME_SUCCESS="4a9c6d"      # green
export THEME_WARNING="d4900a"      # amber (close to gold, intentional)
export THEME_ERROR="c0392b"        # red
export THEME_INFO="2980b9"         # blue

# ── Geometry — MUST match hyprland/general.conf ──────────────────────
export THEME_ROUNDING="15"         # border-radius in px — match Hyprland rounding
export THEME_BORDER_SIZE="1"       # border width in px  — match Hyprland border_size
export THEME_GAPS_OUT="5"          # outer gaps — for bar margin calculations

# ── Typography ────────────────────────────────────────────────────────
export THEME_FONT="JetBrainsMono Nerd Font"
export THEME_FONT_SIZE="13"
export THEME_FONT_WEIGHT="400"

# ── Cursor ────────────────────────────────────────────────────────────
export THEME_CURSOR="Bibata-Modern-Amber"
export THEME_CURSOR_SIZE="24"

# ── Blur / transparency ───────────────────────────────────────────────
# Match these to decoration.blur settings in general.conf
export THEME_BLUR_SIZE="5"
export THEME_BLUR_PASSES="2"
